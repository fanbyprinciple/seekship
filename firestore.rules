rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid} {
      // Own doc: full access. Partner's doc: read + allow partner-linking write
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
      // Allow partner to set partnerId on your doc (invite redeem)
      allow update: if request.auth != null &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['partnerId']);
    }
    match /inviteCodes/{code} {
      allow read, write: if request.auth != null;
    }
    match /messages/{messageId} {
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.fromUid;
      allow read, update: if request.auth != null &&
        (request.auth.uid == resource.data.fromUid ||
         request.auth.uid == resource.data.toUid);
    }
    match /checklists/{partnershipId}/items/{itemId} {
      allow read, write: if request.auth != null &&
        partnershipId.matches('.*' + request.auth.uid + '.*');
    }
  }
}
